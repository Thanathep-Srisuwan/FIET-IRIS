# Server
PORT=5000
NODE_ENV=development

# Database (MSSQL)
DB_SERVER=localhost\SQLEXPRESS
# Leave DB_PORT empty when using a named instance such as localhost\SQLEXPRESS.
# Set DB_SERVER=localhost and DB_PORT=1433 for a fixed-port/default instance.
DB_PORT=
DB_NAME=FIET_IRIS
DB_USER=
DB_PASSWORD=

# JWT
JWT_SECRET=your_super_secret_key_change_this
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this
JWT_REFRESH_EXPIRES_IN=7d

# Email (Nodemailer)
MAIL_HOST=smtp.office365.com
MAIL_PORT=587
MAIL_USER=noreply@kmutt.ac.th
MAIL_PASS=your_email_password
MAIL_FROM=FIET IRIS <noreply@kmutt.ac.th>

# File Upload
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=10

# Frontend URL (CORS)
CLIENT_URL=http://localhost:5173
